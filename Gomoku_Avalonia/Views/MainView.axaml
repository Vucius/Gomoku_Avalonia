<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Gomoku_Avalonia.ViewModels"
             xmlns:views="using:Gomoku_Avalonia.Views"
             mc:Ignorable="d"
             d:DesignWidth="420"
             d:DesignHeight="820"
             x:Class="Gomoku_Avalonia.Views.MainView"
             x:DataType="vm:MainViewModel">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid Background="#111318" RowDefinitions="46,*,214">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="8"
              Margin="8,6,8,4">
            <TextBlock Text="Gomoku"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#f4f1e8"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{Binding StatusText}"
                       FontSize="12"
                       Foreground="#b8c0cc"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="2"
                        Spacing="2"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding CompactScoreText}"
                           Foreground="#f4f1e8"
                           FontSize="11"
                           HorizontalAlignment="Right" />
                <TextBlock Text="{Binding NetworkStatusText}"
                           Foreground="#8fe6a0"
                           FontSize="11"
                           HorizontalAlignment="Right" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="8,0">
            <views:GomokuBoardView Board="{Binding Board}"
                                   MoveVersion="{Binding MoveVersion}"
                                   LastMove="{Binding LastMove}"
                                   HintMove="{Binding HintMove}"
                                   WinningCells="{Binding WinningCells}"
                                   Skin="{Binding BoardSkin}"
                                   CellSelectedCommand="{Binding PlaceHumanMoveCommand}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />

            <Border IsVisible="{Binding IsNetworkWaitVisible}"
                    Background="#dd1f2630"
                    BorderBrush="#f0a33c"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="8">
                <TextBlock Text="{Binding NetworkWaitText}"
                           Foreground="#fff2d2"
                           FontSize="12"
                           TextWrapping="Wrap"
                           MaxWidth="340" />
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="8,4,8,8"
                Background="#1b2028"
                BorderBrush="#303946"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8">
            <Grid RowDefinitions="34,34,34,*,24"
                  ColumnDefinitions="*,*,*,*"
                  RowSpacing="6"
                  ColumnSpacing="6">
                <Button Content="New"
                        Command="{Binding NewGameCommand}"
                        HorizontalAlignment="Stretch" />
                <Button Grid.Column="1"
                        Content="Undo"
                        Command="{Binding UndoCommand}"
                        HorizontalAlignment="Stretch" />
                <Button Grid.Column="2"
                        Content="Hint"
                        Command="{Binding RequestHintCommand}"
                        HorizontalAlignment="Stretch" />
                <Button Grid.Column="3"
                        Content="{Binding SkinButtonText}"
                        Command="{Binding ToggleSkinCommand}"
                        HorizontalAlignment="Stretch" />

                <ToggleSwitch Grid.Row="1"
                              Grid.ColumnSpan="2"
                              IsChecked="{Binding IsAiFirst}"
                              Content="{Binding OpeningText}"
                              FontSize="12" />
                <ComboBox Grid.Row="1"
                          Grid.Column="2"
                          Grid.ColumnSpan="2"
                          ItemsSource="{Binding ModelOptions}"
                          SelectedItem="{Binding SelectedModel}"
                          HorizontalAlignment="Stretch" />

                <TextBox Grid.Row="2"
                         Grid.ColumnSpan="3"
                         Text="{Binding ApiBaseUrl}"
                         FontSize="12"
                         PlaceholderText="https://mitsutake-model-space.hf.space" />
                <Button Grid.Row="2"
                        Grid.Column="3"
                        Content="Save"
                        Command="{Binding ApplySettingsCommand}"
                        HorizontalAlignment="Stretch" />

                <TextBlock Grid.Row="3"
                           Grid.ColumnSpan="4"
                           Text="{Binding HintText}"
                           Foreground="#9fc7ff"
                           FontSize="12"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="4"
                           Grid.ColumnSpan="4"
                           Text="{Binding MoveLogText}"
                           Foreground="#cbd3df"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsSettingsOpen}"
                Background="#aa080b10"
                Grid.RowSpan="3">
            <Border Width="380"
                    MaxWidth="380"
                    Background="#202733"
                    BorderBrush="#3b4655"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="12">
                    <TextBlock Text="Settings"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#f4f1e8" />
                    <TextBlock Text="API Base URL"
                               Foreground="#b8c0cc" />
                    <TextBox Text="{Binding ApiBaseUrl}"
                             PlaceholderText="https://mitsutake-model-space.hf.space or Vercel proxy" />
                    <TextBlock Text="Model"
                               Foreground="#b8c0cc" />
                    <ComboBox ItemsSource="{Binding ModelOptions}"
                              SelectedItem="{Binding SelectedModel}"
                              HorizontalAlignment="Stretch" />
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8">
                        <Button Content="Cancel"
                                Command="{Binding CloseSettingsCommand}"
                                HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1"
                                Content="Apply"
                                Command="{Binding ApplySettingsCommand}"
                                HorizontalAlignment="Stretch" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
